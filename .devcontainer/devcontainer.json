{
  "name": "c11tester-bounded-window",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "options": ["--platform=linux/amd64"]
  },
  "remoteUser": "c11tester",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "runArgs": [
    "--platform=linux/amd64",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],
  "containerEnv": {
    "LD_LIBRARY_PATH": "/home/c11tester/c11tester:/home/c11tester/c11tester-relaxed:${containerEnv:LD_LIBRARY_PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish"
      }
    }
  }
}